# MongoDB connection string (default: mongodb://localhost:27017/fraud_warning_system)
MONGO_URI=mongodb://localhost:27017/fraud_warning_system

# JWT secret for auth tokens (use a strong secret in production)
JWT_SECRET=your-secret-key-change-in-production

# Optional: server port (default: 5000)
# PORT=5000

# URL of ML service API (no trailing slash). Backend calls POST {ML_SERVICE_URL}/analyze
# Example: https://fraudwatch-ml.onrender.com
ML_SERVICE_URL=http://localhost:5001

# Optional: axios timeout in ms when calling ML (default 15000)
# ML_SERVICE_TIMEOUT_MS=15000

# Allowed frontend origins (comma-separated)
# Example: https://fraudwatch-frontend.onrender.com,https://yourdomain.com
CLIENT_URLS=http://localhost:5173,http://localhost:3000
